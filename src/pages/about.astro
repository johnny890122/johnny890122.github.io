---
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="About | Hsiang-Hsien Chang"
	description="About Hsiang-Hsien Chang — Product Manager focused on payments, data, and end-to-end product delivery."
>
	<div class="stack gap-20">
		<main class="wrapper about">
			<Hero
				title="About"
				tagline="Product Manager with a strong analytical background, building payment and data products from 0 to 1."
			>
			</Hero>

			<section>
				<h2 class="section-title">Background</h2>
				<div class="content">
					<p>
						Product Manager with 1.5+ years of experience in the FinTech and payments space,
						skilled at owning the end-to-end product lifecycle from 0-to-1. Proven ability to
						translate market analysis and user feedback into clear product requirements and
						data-driven roadmaps.
					</p>
					<p>
						Hands-on experience leading payment solution integrations (Stripe, PayPal, Venmo),
						reviewing API documentation to define technical requirements, and driving execution
						within an Agile framework (Jira, Confluence).
					</p>
					<p>
						Backed by a strong analytical background (M.A. Economics, NTU) to conduct rigorous
						post-launch analysis and deliver impactful results. Based in Taipei, Taiwan.
					</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Employment</h2>
				<div class="content">
					<p>
						<strong>Product Manager, MobLab</strong> — Sep 2024 – Present<br />
						Led end-to-end integration of multi-gateway payment solutions (Stripe, PayPal, Venmo)
						and designed risk-control features supporting growth to 5,000+ active users.
					</p>
					<p>
						<strong>R&amp;D Strategist (Contract), Gensler</strong> — Apr 2025 – Present<br />
						Built a novel analytical framework and proprietary "City Development Index" to
						benchmark urban development across 10+ (scaling to 100+) cities.
					</p>
					<p>
						<strong>Data Analyst Intern, ANIWARE</strong> — Jan 2023 – Dec 2023<br />
						Led development of an AI-powered pet care advisor using LLMs and defined quality
						evaluation across 40+ scenarios with a 96.7% pass rate.
					</p>
					<p>
						<strong>Project Engineering Intern, Shopee</strong> — Jan 2022 – Sep 2022<br />
						Delivered a real-time tracking solution for 4,000+ logistics assets and automated
						performance evaluations for 70+ workers, reducing processing time by 90%.
					</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Education</h2>
				<div class="content">
					<p>
						<strong>Master of Arts in Economics</strong>, National Taiwan University — 2022–2024<br
						/>
						Awards: 2024 Taiwan Economic Association Master's Thesis Award; Bank of Taiwan Dissertation
						Silver Award. Thesis: "The Choice of Invoice Currency for Taiwanese Exporters" (with J.-T.
						Liu, 2024).
					</p>
					<p>
						<strong>Bachelor of Arts in Economics</strong>, National Taiwan University — 2018–2022<br
						/>
						Special Second Field: Data Science and Social Inquiry. Cumulative GPA: 3.94 / 4.3.
					</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Skills</h2>
				<div class="content">
					<p>
						<strong>Product Management:</strong> API Integration &amp; Specification, Product Roadmap,
						Requirements Discovery, User Stories, Acceptance Criteria, Agile/Scrum (Jira, Confluence).
					</p>
					<p>
						<strong>Data &amp; Analytics:</strong> Performance Tracking, Hypothesis-Driven Iteration,
						Statistical Analysis, Pandas, noSQL.
					</p>
					<p>
						<strong>Technical Proficiency:</strong> Python, LLM Workflows (Gemini, OpenRouter),
						AWS (Lambda, API Gateway), Heroku, MongoDB, Git.
					</p>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}
</style>
